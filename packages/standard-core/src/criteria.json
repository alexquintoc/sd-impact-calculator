  "pillars": [
    {
      "id": "environmental",
      "label": "Environmental",
      "criteria": [
        {
          "id": "E1",
          "label": "Reduces carbon footprint",
          "points": 10,
          "summary": "Includes at least one meaningful step to reduce emissions or energy use across the project lifecycle.",
          "description": "The project strategy includes at least one action to reduce environmental impact.",
          "whyItMatters": "Early design decisions can significantly reduce emissions across materials, production, and distribution.",
          "examples": [
            "Reducing page count",
            "Choosing lower-impact materials",
            "Optimizing digital assets"
          ],
          "terms": ["carbon-footprint"]
        },
        { "id": "E2", "label": "Habitat Conservation", "points": 15 },
        { "id": "E3", "label": "Product Ingredients List", "points": 10 },
        { "id": "E4", "label": "Ink, Printing, and Finishes", "points": 10 },
        { "id": "E5", "label": "Paper", "points": 15 },
        { "id": "E6", "label": "Product Quantity", "points": 10 }
      ]
    },
    {
      "id": "social",
      "label": "Social",
      "criteria": [
        { "id": "soc1", "label": "Improves community well-being", "points": 15 },
        { "id": "soc2", "label": "Ensures fair labor practices", "points": 15 },
        { "id": "soc3", "label": "Accessible and inclusive design", "points": 10 },
        { "id": "soc4", "label": "Fosters user health and safety", "points": 10 },
