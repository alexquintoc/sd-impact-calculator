      "criteria": [
        { "id": "cul1", "label": "Respects cultural heritage", "points": 15 },
        { "id": "cul2", "label": "Promotes diversity of thought", "points": 10 },
        { "id": "cul3", "label": "Avoids cultural appropriation", "points": 15 },
        { "id": "cul4", "label": "Encourages artistic expression", "points": 10 },
        { "id": "cul5", "label": "Supports indigenous practices", "points": 10 },
        { "id": "cul6", "label": "Fosters cross-cultural understanding", "points": 10 }
      ]
    },
    {
      "id": "financial",
      "label": "Financial",
      "criteria": [
        { "id": "fin1", "label": "Long-term economic viability", "points": 15 },
        { "id": "fin2", "label": "Transparent pricing", "points": 10 },
        { "id": "fin3", "label": "Fair value distribution", "points": 15 },
        { "id": "fin4", "label": "Affordable for target users", "points": 10 },
        { "id": "fin5", "label": "Supports local economies", "points": 10 },
        { "id": "fin6", "label": "Responsible investment", "points": 10 }
